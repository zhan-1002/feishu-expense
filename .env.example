# 飞书应用配置（必需）
FEISHU_BASE_TOKEN=your_base_token_here
FEISHU_APP_ID=your_app_id_here
FEISHU_CLI_PROFILE=your_cli_profile_here

# lark-cli 路径（可选，默认 "lark-cli"）
LARK_CLI=lark-cli

# 飞书应用密钥（可选，CLI 模式下非必需）
FEISHU_APP_SECRET=

# ---- 费用报销模块 ----
EXPENSE_TABLE_ID=your_table_id_here

# ---- 选品ERP模块 ----
# 通知群 chat_id（Bot 需在群中）
NOTIFY_GROUP_CHAT_ID=oc_xxxxxxxx
# 主管 open_id 列表（逗号分隔）
MANAGER_OPEN_IDS=ou_xxxxxxxx
